{
  "name": "rollup-plugin-html2",
  "version": "5.0.1",
  "description": "Rollup plugin to inject bundled files to an HTML templates.",
  "homepage": "https://mentaljam.github.io/rollup-plugin-html2",
  "repository": {
    "type": "git",
    "url": "git+ssh://github.com/mentaljam/rollup-plugin-html2"
  },
  "bugs": {
    "url": "https://github.com/mentaljam/rollup-plugin-html2/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prebuild": "pnpm run lint",
    "build": "tsc -p tsconfig.lib.json",
    "docs": "pnpm dlx typedoc@0.28.19",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit",
    "lint": "eslint",
    "pretest": "tsc -p tsconfig.lib.json",
    "test": "node --experimental-test-coverage --test test/**/*.test.ts"
  },
  "keywords": [
    "rollup",
    "plugin",
    "html"
  ],
  "author": "Petr Tsymbarovich <petr@tsymbarovich.ru>",
  "license": "MIT",
  "dependencies": {
    "html-minifier-next": "^7.0.0",
    "node-html-parser": "^7.1.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.3",
    "eslint": "10.5.0",
    "rollup": "4.62.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1"
  },
  "peerDependencies": {
    "html-minifier-next": ">=7.0",
    "rollup": ">=3.0"
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
